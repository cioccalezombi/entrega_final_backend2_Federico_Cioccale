# Puerto donde va a escuchar Express
PORT=3000

# URI de conexión a MongoDB Atlas (Completar con tu propia URI)
MONGO_URI=mongodb+srv://<usuario>:<password>@cluster...

# Secreto para firmar JWT (Cualquier cadena segura. Ejemplo: duhalde2027)
JWT_SECRET=duhalde2027

# Credenciales para Nodemailer (Gmail)
EMAIL_USER=tuemail@gmail.com
EMAIL_PASS=tu_app_password

# URL del frontend para armar el link de reset de contraseña
FRONTEND_URL=http://localhost:5173
